<?xml version="1.0"?>
<robot name="diuniu">

  <!-- 定义全新材质：工业橙色(带 40% 透明度，方便看内部结构) -->
  <material name="orange"><color rgba="1.0 0.5 0.0 0.6"/></material>
  <material name="black"><color rgba="0.2 0.2 0.2 1.0"/></material>
  <material name="blue"><color rgba="0.0 0.5 1.0 1.0"/></material>
  <material name="red"><color rgba="0.8 0.0 0.0 1.0"/></material>

  <!-- 1. 核心原点：base_link (位于两后轮中心) -->
  <link name="base_link">
    <visual>
      <!-- 将车身 Z 轴抬高至 0.18m (留出8cm底盘离地间隙)，让轮子从底盘下面露出来 -->
      <origin xyz="0.675 0 0.18" rpy="0 0 0"/>
      <geometry>
        <!-- 真实尺寸：长 1.85m, 宽 0.7m, 高 0.2m -->
        <box size="1.85 0.7 0.2"/>
      </geometry>
      <!-- 使用半透明橙色 -->
      <material name="orange"/>
    </visual>
  </link>

  <!-- 2. 前驱动/转向轮 -->
  <link name="front_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.085" length="0.08"/></geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="front_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_wheel"/>
    <!-- 前轮位于后轮正前方 1.3m 处 -->
    <origin xyz="1.3 0 0.085" rpy="0 0 0"/>
  </joint>

  <!-- 3. 左后轮 -->
  <link name="rear_left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.085" length="0.05"/></geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="rear_left_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <!-- 轮距 0.53m 的一半是 0.265m -->
    <origin xyz="0 0.265 0.085" rpy="0 0 0"/>
  </joint>

  <!-- 4. 右后轮 -->
  <link name="rear_right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.085" length="0.05"/></geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="rear_right_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rear_right_wheel"/>
    <origin xyz="0 -0.265 0.085" rpy="0 0 0"/>
  </joint>

  <!-- 5. 传感器：IMU 安装位置 -->
  <link name="imu_link">
    <visual>
      <geometry><box size="0.05 0.05 0.02"/></geometry>
      <material name="blue"/>
    </visual>
  </link>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <!-- 假设装在正中间 -->
    <origin xyz="0.675 0 0.2" rpy="0 0 0"/> 
  </joint>

  <!-- 6. 传感器：激光雷达安装位置 -->
  <link name="laser_link">
    <visual>
      <!-- 给雷达加一个小红圆柱做外观 -->
      <geometry><cylinder radius="0.035" length="0.05"/></geometry>
      <material name="red"/>
    </visual>
  </link>
  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_link"/>
    <!-- 雷达位于驱动轮/转向轮向后 8.5cm，坐标是 1.3 - 0.085 = 1.215m -->
    <!-- 假设高度装在 0.6m 处，可根据实际支架高度修改 Z 值 -->
    <origin xyz="1.215 0 0.6" rpy="0 0 0"/> 
  </joint>

</robot>
